{
  "name": "@lap/managed-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./memory": {
      "types": "./dist/memory.d.ts",
      "default": "./dist/memory.js"
    },
    "./automations": {
      "types": "./dist/automations.d.ts",
      "default": "./dist/automations.js"
