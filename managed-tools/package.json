    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node --test test/"
  },
  "dependencies": {
    "undici": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
