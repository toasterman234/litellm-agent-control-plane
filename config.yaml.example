model_list:
  - model_name: anthropic/*
    litellm_params:
      model: anthropic/*
      api_key: os.environ/ANTHROPIC_API_KEY
      api_base: https://api.anthropic.com

  # OpenAI Responses API, used by Codex (CLI + Mac app). Keep OpenAI routes
  # explicit because only one wildcard model route is supported.
  - model_name: gpt-5.5
    litellm_params:
      model: openai/gpt-5.5
      api_key: os.environ/OPENAI_API_KEY
      api_base: https://api.openai.com
  - model_name: gpt-4.1
    litellm_params:
      model: openai/gpt-4.1
      api_key: os.environ/OPENAI_API_KEY
      api_base: https://api.openai.com
  - model_name: gpt-4.1-mini
    litellm_params:
      model: openai/gpt-4.1-mini
      api_key: os.environ/OPENAI_API_KEY
      api_base: https://api.openai.com

  # Free-provider chat-completions routes. Keep these explicit because only
  # one wildcard model route is supported.
  - model_name: gemini-3.5-flash
    litellm_params:
      model: gemini_chat/gemini-3.5-flash
      api_key: os.environ/GEMINI_API_KEY
      api_base: https://generativelanguage.googleapis.com/v1beta/openai
  - model_name: mistral-small-latest
    litellm_params:
      model: mistral/mistral-small-latest
      api_key: os.environ/MISTRAL_API_KEY
      api_base: https://api.mistral.ai/v1
  - model_name: groq-gpt-oss-20b
    litellm_params:
      model: groq/openai/gpt-oss-20b
      api_key: os.environ/GROQ_API_KEY
      api_base: https://api.groq.com/openai/v1
  - model_name: groq-llama-3.1-8b-instant
    litellm_params:
      model: groq/llama-3.1-8b-instant
      api_key: os.environ/GROQ_API_KEY
      api_base: https://api.groq.com/openai/v1
  - model_name: cerebras-gpt-oss-120b
    litellm_params:
      model: cerebras/gpt-oss-120b
      api_key: os.environ/CEREBRAS_API_KEY
      api_base: https://api.cerebras.ai/v1

general_settings:
  master_key: os.environ/LITELLM_MASTER_KEY
  database_url: os.environ/DATABASE_URL
  store_prompts_in_spend_logs: true
  sandbox_choice: e2b
  e2b_sandbox_params:
    e2b_api_key: os.environ/E2B_API_KEY
    e2b_template: litellm-4gb
    envs:
      ANTHROPIC_API_KEY: os.environ/ANTHROPIC_API_KEY

slack:
  api_base_url: https://slack.com/api

# MCP servers use the same dict-keyed shape as LiteLLM (key = server name).
mcp_servers:
  proxy_base_url: os.environ/LITELLM_PROXY_BASE_URL
  linear:
    url: os.environ/LINEAR_MCP_URL
    auth_type: bearer_token            # none | api_key | bearer_token | basic | authorization | token
    auth_value: os.environ/LINEAR_MCP_API_KEY
  docs:
    url: https://mcp.example.com/mcp
    auth_type: api_key                 # sent as `X-API-Key: <auth_value>`
    auth_value: os.environ/DOCS_MCP_API_KEY
    static_headers:                    # always sent upstream
      x-workspace: prod

agents:
  - name: Untitled agent
    description: A blank starting point with the core toolset.
    model: claude-sonnet-4-6
    system: You are a general-purpose agent that can research, write code, run commands, and use connected tools to complete the user's task end to end.
    mcp_servers: []
    tools:
      - type: bash
      - type: read
      - type: write
      - type: edit
      - type: glob
      - type: grep
      - type: web_fetch
      - type: web_search
    skills: []
