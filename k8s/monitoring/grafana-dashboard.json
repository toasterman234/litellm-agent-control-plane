{
  "title": "Agent Platform — Session Reliability",
  "uid": "agent-session-reliability",
  "description": "Answers: (1) How reliably are we spawning sessions? (2) Why are we unreliable? (3) Where is time lost?",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "tags": ["agent-platform", "reliability"],
  "panels": [

    {
      "id": 1,
      "title": "Spawn Success Rate",
      "description": "session_spawn_total{result=success} / total. Target ≥ 98%.",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(session_spawn_total{result=\"success\"}[5m])) / sum(rate(session_spawn_total[5m])) * 100",
          "legendFormat": "success rate"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "noValue": "No data",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green",  "value": 98 }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 2,
      "title": "Warm Pool Hit Rate",
      "description": "hit / (hit + miss). Low = pool undersized; most sessions take the slow cold path.",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(warm_pool_hit_total[5m]) / (rate(warm_pool_hit_total[5m]) + rate(warm_pool_miss_total[5m])) * 100",
          "legendFormat": "hit rate"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "noValue": "Pool disabled",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green",  "value": 80 }
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 3,
      "title": "Session Spawns / min",
      "description": "Rate of session creates by path and outcome. Warm success should dominate if pool is sized correctly.",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(session_spawn_total{path=\"cold\",result=\"success\"}[1m]) * 60",
          "legendFormat": "cold success"
        },
        {
          "refId": "B",
          "expr": "rate(session_spawn_total{path=\"cold\",result=\"failed\"}[1m]) * 60",
          "legendFormat": "cold failed"
        },
        {
          "refId": "C",
          "expr": "rate(session_spawn_total{path=\"warm\",result=\"success\"}[1m]) * 60",
          "legendFormat": "warm success"
        },
        {
          "refId": "D",
          "expr": "rate(session_spawn_total{path=\"warm\",result=\"failed\"}[1m]) * 60",
          "legendFormat": "warm failed"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cold success" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73bf69", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "cold failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#f2495c", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "warm success" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5794f2", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "warm failed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#b877d9", "mode": "fixed" } }]
          }
        ]
      }
    },

    {
      "id": 4,
      "title": "P95 Spawn Latency — Cold vs Warm (seconds)",
      "description": "Large delta = warm pool is the fix. Cold P95 > 60s = node scheduling or image pull is the bottleneck.",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 5, "w": 16, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, rate(session_spawn_duration_seconds_bucket{path=\"cold\"}[5m]))",
          "legendFormat": "cold P95"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, rate(session_spawn_duration_seconds_bucket{path=\"cold\"}[5m]))",
          "legendFormat": "cold P50"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.95, rate(session_spawn_duration_seconds_bucket{path=\"warm\"}[5m]))",
          "legendFormat": "warm P95"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cold P95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#ff9830", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "cold P50" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "#ff9830", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [4, 4], "fill": "dash" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "warm P95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#5794f2", "mode": "fixed" } }]
          }
        ]
      }
    },

    {
      "id": 5,
      "title": "Failures by Reason",
      "description": "pod_timeout dominant → node scheduling. harness_timeout dominant → repo clone / image pull. cni_exhaustion → cluster IP space.",
      "type": "barchart",
      "gridPos": { "x": 16, "y": 5, "w": 8, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (reason) (increase(session_spawn_failure_total[$__range]))",
          "legendFormat": "{{reason}}",
          "instant": true
        }
      ],
      "options": {
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80 }
        },
        "overrides": []
      }
    },

    {
      "id": 6,
      "title": "Phase Duration — P95 (seconds)  ·  where is time lost?",
      "description": "Tallest bar = bottleneck. pod_pending = node scheduling lag. cloning_repo = repo size / cold image. waiting_harness = harness boot time.",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(session_phase_duration_seconds_bucket{phase=\"pod_pending\"}[10m])))",
          "legendFormat": "pod_pending"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(session_phase_duration_seconds_bucket{phase=\"cloning_repo\"}[10m])))",
          "legendFormat": "cloning_repo"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(session_phase_duration_seconds_bucket{phase=\"waiting_harness\"}[10m])))",
          "legendFormat": "waiting_harness"
        },
        {
          "refId": "D",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(session_phase_duration_seconds_bucket{phase=\"creating_sandbox\"}[10m])))",
          "legendFormat": "creating_sandbox"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color",
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 30 }
            ]
          }
        },
        "overrides": []
      }
    }

  ]
}
