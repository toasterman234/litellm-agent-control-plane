// Lean v0 schema for managed agents on Fargate.
// 2 tables: Agent (config) + Session (live Fargate task instance).
// Plus 3 tables for the integrations subsystem (see src/server/integrations/).
// Snake_case columns to match upstream LiteLLM Prisma conventions in case
// this DB is shared with the Python proxy.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  agent_id            String   @id @default(uuid())
  agent_name          String?
  model               String
  prompt              String?
  tools               Json     @default("[]")
  harness_id          String   @default("opencode")
  repo_url            String?
  branch              String   @default("main")
  pfp_url             String?
  mcp_servers         Json     @default("[]")
  env_vars            Json     @default("{}")
  // Per-credential egress binding: { "<ENV_KEY>": ["api.linear.app", ...] }.
  // The vault only swaps a credential's real value into requests bound for one
  // of its hosts, and each host must also appear in allow_out. Empty/missing =
  // legacy (unbound) — treated per the vault's EGRESS_DEFAULT_DENY flag.
  env_var_hosts       Json     @default("{}")
  allow_out           Json     @default("[]")
  deny_out            Json     @default("[]")
  projects            Json     @default("[]")
  task_definition_arn String
  container_port      Int      @default(4096)
  /**
   * How many memories get pre-loaded into AGENT_PROMPT for this agent at
   * warm-task / cold-task launch. Pinned rows (Memory.pinned = true) are
   * always included on top of this limit, capped server-side by
   * MAX_PINNED_PRELOAD. 0 disables non-pinned preload entirely (only
   * always-on rows show up in the prompt).
   *
   * Surfaced in the UI on /agents/:id/memory as a number input so a user
   * can tune per-agent — agents that work in a high-rule domain (e.g.
   * compliance) may want a larger preload window than the default 10.
   */
  preload_memory_limit Int     @default(10)
  /**
   * Helm-style template provenance. When an agent is created from a template,
   * template_id records which template and template_version records the version
   * synced to. template_version < currentTemplate.version means the agent is
   * out of date — surface a "sync available" affordance in the UI and call
   * POST /agents/:id/template/sync to update. Both null for agents created
   * without a template.
   */
  template_id         String?
  template_version    Int?
  template_prompt     String?  // snapshot of template.prompt at creation/last-sync; used for diff display
  created_at          DateTime @default(now())
  created_by          String?

  sessions             Session[]
  warm_tasks           WarmTask[]
  memories             Memory[]
  issues               AgentIssue[]
  integration_bindings AgentIntegrationBinding[]
  automations          Automation[]

  @@index([created_by])
  @@map("managed_agent")
}

// A scheduled trigger that spawns a session for an agent on a cron cadence.
// Multiple automations per agent (e.g. "weekdays 9am: PR status summary"
// + "hourly: health check") — hence a separate table rather than columns
// on Agent.
//
// Multi-pod safe: the worker claims due rows with
// `SELECT ... FOR UPDATE SKIP LOCKED` and advances next_run_at inside the
// same transaction before firing the session outside the lock window. Two
// pods ticking at the same instant can't double-fire — see
// src/server/automations.ts.
model Automation {
  automation_id String    @id @default(uuid())
  agent_id      String
  name          String?   // optional display label
  instruction   String    // initial_prompt sent when the session spawns
  cron_expr     String    // standard 5-field cron, evaluated in UTC
  enabled       Boolean   @default(true)
  // Pre-computed on create/update and re-computed after each fire so the
  // worker query is a plain range scan — no cron parsing at query time.
  next_run_at   DateTime?
  last_run_at   DateTime?
  created_at    DateTime  @default(now())
  created_by    String?

  agent Agent @relation(fields: [agent_id], references: [agent_id], onDelete: Cascade)
  runs  AutomationRun[]

  // Worker claim path: enabled rows whose next_run_at is due.
  @@index([enabled, next_run_at])
  // Agent detail page: list automations for one agent.
  @@index([agent_id])
  @@map("managed_agent_automation")
}

// One row per time an automation fired. Gives the agent page a run log:
// when each run started, whether it completed, and the session it spawned.
//
// Lifecycle: created `running` when the worker fires the automation (with the
// spawned session_id), then resolved to `succeeded`/`failed` by
// reconcileAutomationRuns() on a later worker tick by inspecting the linked
// session — or `failed` immediately if the session never spawned.
model AutomationRun {
  run_id        String    @id @default(uuid())
  automation_id String
  agent_id      String    // denormalised so the agent-page log is a single-table scan
  session_id    String?   // the spawned session, when bring-up succeeded
  status        String    @default("running") // running | succeeded | failed
  error         String?
  started_at    DateTime  @default(now())
  finished_at   DateTime?

  automation Automation @relation(fields: [automation_id], references: [automation_id], onDelete: Cascade)

  // Agent-page log: most-recent runs for one agent.
  @@index([agent_id, started_at])
  // Completion reconcile: open runs to resolve.
  @@index([status])
  @@map("managed_agent_automation_run")
}

model Session {
  session_id         String    @id @default(uuid())
  agent_id           String
  status             String    @default("creating") // creating | ready | dead | failed
  // Fine-grained bring-up phase, written by coldBringUp / warmBringUp /
  // finishBringUp at each step and by the in-sandbox harness for stages
  // it owns (cloning_repo, installing_deps, harness_listening). Null on
  // legacy rows created before this column existed — the UI falls back
  // to a wall-clock approximation for those. See SessionPhase in
  // src/server/types.ts for the closed set of values.
  phase              String?
  // Optional free-form detail for the current phase ("cloning <repo>",
  // "installing 42 packages", …). Rendered as a small subtitle under the
  // active step in the UI; safe to leave null.
  phase_detail       String?
  task_arn           String?
  sandbox_url        String?
  harness_session_id String?
  failure_reason     String?
  response           Json?     // last harness reply blob (initial_prompt and most-recent message)
  // Denormalized cache of the opencode thread ([{info, parts}, ...]), refreshed
  // best-effort after every send. Kept for the title preview + dead-session UI
  // fallback. The durable, append-only source of truth for recovery is the
  // SessionMessage table — see src/server/sessionStore.ts.
  history            Json?
  pending_assistant_parts Json? // HarnessMessagePart[] accumulated during an in-flight or interrupted stream turn; shown when harness thread is missing the assistant response
  sandboxes          Json?     // map of sandbox name → sandbox URL: { "litellm-bug": "http://s-xxx.default.svc.cluster.local:4096" }
  created_at         DateTime  @default(now())
  created_by         String?
  last_seen_at       DateTime?
  stopped_at         DateTime?

  agent               Agent               @relation(fields: [agent_id], references: [agent_id], onDelete: Cascade)
  integration_session IntegrationSession?
  messages            SessionMessage[]
  assessments         SessionAssessment[]

  @@index([agent_id])
  @@index([status])
  @@index([last_seen_at])
  @@map("managed_agent_session")
}

// Append-only, durable record of a session's conversation. One row per turn
// (role=user | assistant). Unlike Session.history (a single blob overwritten
// after each reply), rows here are written *before* the harness call for the
// user turn and on reply for the assistant turn — so a sandbox that dies
// mid-turn still leaves the user's message recoverable. This is the source of
// truth that rehydrateSession() replays into a fresh sandbox. See
// src/server/sessionStore.ts. Conversation-only: no filesystem/tool state.
model SessionMessage {
  message_id         String    @id @default(uuid())
  session_id         String
  // Which harness session produced/consumed this turn. Changes across a
  // rehydrate (new pod = new harness_session_id); kept for debugging only.
  harness_session_id String?
  seq                Int       // monotonic order within the session, 0-based
  role               String    // user | assistant
  status             String    @default("pending") // pending | complete | failed
  parts              Json      // HarnessMessagePart[] (text/image/tool blobs)
  created_at         DateTime  @default(now())
  completed_at       DateTime?

  session Session @relation(fields: [session_id], references: [session_id], onDelete: Cascade)

  @@unique([session_id, seq])
  @@index([session_id, created_at])
  @@map("managed_agent_session_message")
}

// Latest and historical reviewer judgments for a session. The platform
// reviewer polls active sessions on a fixed cadence and records whether
// each run is still on track, slow-but-healthy, or blocked.
model SessionAssessment {
  assessment_id     String   @id @default(uuid())
  session_id        String
  state             String   @default("on_track") // on_track | slow_but_ok | off_track | blocked | failed
  severity          String   @default("info")     // info | med | high
  blocker_type      String?
  diagnosis         String
  recommended_action String?
  confidence        Int      @default(50)
  evidence          Json     @default("[]")
  action_status     String   @default("none")     // none | watching | queued | executed | failed
  action_ref        String?
  // Session ID of the spawned LAP reviewer agent session that critiques this
  // target session. The reviewer session IS the review — open it to read
  // the agent's analysis. Spawned once per target-session lifetime so the
  // worker can re-poll the same critique over multiple ticks without
  // re-spawning. Null until the worker first decides the target needs a
  // deeper review (state moves off on_track / slow_but_ok).
  reviewer_session_id String?
  checked_at        DateTime @default(now())
  next_check_at     DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  session Session @relation(fields: [session_id], references: [session_id], onDelete: Cascade)

  @@index([session_id, checked_at])
  @@index([state, checked_at])
  @@map("managed_agent_session_assessment")
}

// Pre-provisioned Fargate task waiting to be claimed by a session create.
// One row per pool slot. Tasks are bound to a single agent because the
// opencode harness reads REPO_URL / BRANCH / AGENT_PROMPT from container
// env at boot, so a warm task for agent A can't serve a request for agent B.
//
// Lifecycle: provisioning -> warm -> claimed -> (row deleted; task lives on
// inside the corresponding Session). dead is the terminal failure state —
// reconciler stops the underlying ECS task and the row is removed on the
// next sweep.
model WarmTask {
  warm_task_id   String    @id @default(uuid())
  agent_id       String
  status         String    @default("provisioning") // provisioning | warm | claimed | dead
  task_arn       String?
  sandbox_url    String?
  failure_reason String?
  created_at     DateTime  @default(now())
  ready_at       DateTime?
  claimed_at     DateTime?

  agent Agent @relation(fields: [agent_id], references: [agent_id], onDelete: Cascade)

  // Primary claim path: oldest warm row for this agent.
  @@index([agent_id, status, ready_at])
  // Sweeps: TTL recycle, orphan detection.
  @@index([status, created_at])
  @@map("managed_agent_warm_task")
}

// Per-agent durable memory. One row = one lesson the agent should apply on
// future runs ("for UI changes use shadcn Tag", "PR titles start with fix:").
// Read paths:
//   1. Top-10 by priority+usage pre-loaded into AGENT_PROMPT at warm-task
//      launch (instinctive awareness).
//   2. Searched on demand via /memory?q=... — grep-style ILIKE + tag intersect.
//      Mandatory checkpoint before the agent finalizes a PR.
// Write paths:
//   - Agent tool save_memory (source=agent) — model decides during run.
//   - Slack `remember:` prefix → shin → LAP API (source=slack).
//   - Direct UI (source=ui).
// On any write/update/disable: invalidateWarmTasks(agent_id) marks all warm
// tasks dead so the pool re-provisions with a fresh pre-loaded prompt.
model Memory {
  memory_id         String   @id @default(uuid())
  agent_id          String
  text              String

  tags              String[]                       // 1-4 short labels (ui, antd, security, …)
  type              String   @default("convention") // convention | constraint | reference | preference

  priority          Int      @default(0)           // higher = listed first in prompt + UI
  disabled          Boolean  @default(false)       // soft-hide from prompt and search
  // When true, this row is unconditionally included in the AGENT_PROMPT
  // pre-load — independent of the priority+usage ranking dial. Distinct
  // from priority: priority is a tie-breaker for the bounded preload
  // window, pinned bypasses that ranking. Capped server-side at
  // MAX_PINNED_PRELOAD (see src/server/memory.ts) so the prompt can't be
  // blown up by marking everything pinned. UI surfaces this as the
  // "📌 Always on" toggle on the per-agent memory page.
  pinned            Boolean  @default(false)

  times_applied     Int      @default(0)           // bumped each time search_memory returns this row
  last_applied_at   DateTime?

  source            String   @default("agent")     // agent | slack | ui
  source_user_id    String?
  source_session_id String?                              // no FK — memory intentionally outlives sessions
  source_thread_ts  String?

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  agent Agent @relation(fields: [agent_id], references: [agent_id], onDelete: Cascade)

  // Primary read path: active memories for an agent, ordered by priority.
  // Pinned column added so the preload query can use a partial index on
  // pinned rows without rebuilding this composite.
  @@index([agent_id, disabled, priority])
  @@index([agent_id, pinned], map: "Memory_agent_pinned_idx")
  @@map("managed_agent_memory")
}

// Issues reported by the agent via the `report_issue` MCP tool. One row per
// issue. The UI surfaces these on the agent detail page so operators can see
// every problem the agent reported across all its sessions in one place.
model AgentIssue {
  issue_id    String   @id @default(uuid())
  agent_id    String
  session_id  String?  // which session reported it; no FK — issues outlive sessions
  title       String
  body        String?
  severity    String   @default("info")  // info | warning | error | critical
  status      String   @default("open")  // open | resolved | dismissed
  times_seen  Int      @default(1)
  created_at  DateTime @default(now())

  agent    Agent               @relation(fields: [agent_id], references: [agent_id], onDelete: Cascade)
  comments AgentIssueComment[]

  @@index([agent_id, status, created_at])
  @@map("managed_agent_issue")
}

model AgentIssueComment {
  comment_id  String   @id @default(uuid())
  issue_id    String
  session_id  String?
  body        String
  created_at  DateTime @default(now())

  issue AgentIssue @relation(fields: [issue_id], references: [issue_id], onDelete: Cascade)

  @@index([issue_id, created_at])
  @@map("managed_agent_issue_comment")
}

// =============================================================================
// Integrations subsystem (src/server/integrations/)
// =============================================================================
// Three tables let any external medium (Linear, Slack, GitHub, ...) delegate
// work to an Agent and stream activity back. The integration_id column is a
// string discriminator — one row in src/server/integrations/providers/ per
// distinct value. Adding a new medium requires no Agent schema migration.
// =============================================================================

/// One row per OAuth install (per workspace, per integration). Owns the
/// access + refresh tokens for talking back to the medium's API. Tokens are
/// AES-GCM encrypted at rest by core/crypto.ts when ENCRYPTION_KEY is
/// configured (required in production).
model IntegrationInstall {
  install_id     String    @id @default(uuid())
  integration_id String    // "linear" | "slack" | "github" | ...
  workspace_id   String    // medium's org/team id (e.g. Linear organizationId)
  workspace_name String
  access_token   String    // encrypted
  refresh_token  String?   // encrypted
  expires_at     DateTime?
  metadata       Json      @default("{}") // medium-specific extras: app_user_id, bot_user_id, etc.
  created_at     DateTime  @default(now())
  created_by     String?

  bindings AgentIntegrationBinding[]

  @@unique([integration_id, workspace_id])
  @@map("integration_install")
}

/// Binds one Agent to one IntegrationInstall. The presence of an enabled row
/// is "this agent is reachable via this integration" — there is no boolean
/// column on Agent. Add a new integration without an Agent schema migration.
model AgentIntegrationBinding {
  binding_id String   @id @default(uuid())
  agent_id   String
  install_id String
  enabled    Boolean  @default(true)
  config     Json     @default("{}") // per-binding tunables (e.g. team scope filters)
  created_at DateTime @default(now())

  agent             Agent                @relation(fields: [agent_id],   references: [agent_id],   onDelete: Cascade)
  install           IntegrationInstall   @relation(fields: [install_id], references: [install_id], onDelete: Cascade)
  external_sessions IntegrationSession[]

  @@unique([agent_id, install_id])
  @@index([install_id])
  @@map("agent_integration_binding")
}

model Project {
  project_id  String   @id @default(uuid())
  name        String
  description String?
  repo_url    String?
  env_vars    Json     @default("{}")
  allow_out   Json     @default("[]")
  deny_out    Json     @default("[]")
  files       Json     @default("[]")
  created_by  String?
  created_at  DateTime @default(now())

  @@index([created_by])
  @@map("project")
}

model Skill {
  skill_id    String         @id @default(uuid())
  name        String
  description String?
  content     String
  created_by  String?
  created_at  DateTime       @default(now())
  versions    SkillVersion[]

  @@index([created_by])
  @@map("skill")
}

model SkillVersion {
  id                String   @id @default(uuid())
  skill_id          String
  content           String
  version_number    Int
  changed_by_session_id String?
  created_at        DateTime @default(now())
  skill             Skill    @relation(fields: [skill_id], references: [skill_id], onDelete: Cascade)

  @@index([skill_id, version_number])
  @@map("skill_version")
}

/// Maps a medium's session id (e.g. Linear agentSession.id) to a LAP Session.
/// Written by the dispatcher when a "new_task" event creates a Session;
/// looked up by "followup" / "cancel" events to find the right LAP session.
model IntegrationSession {
  external_session_id String   @id        // medium's id
  session_id          String   @unique    // LAP managed_agent_session.session_id
  binding_id          String
  external_ref        String?             // "LIT-1234", PR url, etc. — for logs
  last_status         String?             // last Session.status we forwarded as an activity
  last_pr_url         String?
  created_at          DateTime @default(now())

  session Session                 @relation(fields: [session_id], references: [session_id], onDelete: Cascade)
  binding AgentIntegrationBinding @relation(fields: [binding_id], references: [binding_id], onDelete: Cascade)

  @@index([binding_id])
  @@map("integration_session")
}
