// Lean v0 schema for managed agents on Fargate.
// 2 tables: Agent (config) + Session (live Fargate task instance).
// Plus 3 tables for the integrations subsystem (see src/server/integrations/).
// Snake_case columns to match upstream LiteLLM Prisma conventions in case
// this DB is shared with the Python proxy.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agent {
  agent_id            String   @id @default(uuid())
  agent_name          String?
  model               String
  prompt              String?
  tools               Json     @default("[]")
  harness_id          String   @default("opencode")
  repo_url            String?
  branch              String   @default("main")
  pfp_url             String?
  mcp_servers         Json     @default("[]")
  task_definition_arn String
  container_port      Int      @default(4096)
  created_at          DateTime @default(now())
  created_by          String?

  sessions             Session[]
  warm_tasks           WarmTask[]
  memories             Memory[]
  integration_configs  AgentIntegrationConfig[]
  integration_installs IntegrationInstall[]

  @@index([created_by])
  @@map("managed_agent")
}

model Session {
  session_id         String    @id @default(uuid())
  agent_id           String
  status             String    @default("creating") // creating | ready | dead | failed
  task_arn           String?
  sandbox_url        String?
  harness_session_id String?
  failure_reason     String?
  response           Json?     // last harness reply blob (initial_prompt and most-recent message)
  history            Json?     // full opencode thread snapshot ([{info, parts}, ...]); refreshed after every send so a restarted pod can replay it
  created_at         DateTime  @default(now())
  created_by         String?
  last_seen_at       DateTime?
  stopped_at         DateTime?

  agent               Agent               @relation(fields: [agent_id], references: [agent_id], onDelete: Cascade)
  integration_session IntegrationSession?

  @@index([agent_id])
  @@index([status])
  @@index([last_seen_at])
  @@map("managed_agent_session")
}

// Pre-provisioned Fargate task waiting to be claimed by a session create.
// One row per pool slot. Tasks are bound to a single agent because the
// opencode harness reads REPO_URL / BRANCH / AGENT_PROMPT from container
// env at boot, so a warm task for agent A can't serve a request for agent B.
//
// Lifecycle: provisioning -> warm -> claimed -> (row deleted; task lives on
// inside the corresponding Session). dead is the terminal failure state —
// reconciler stops the underlying ECS task and the row is removed on the
// next sweep.
model WarmTask {
  warm_task_id   String    @id @default(uuid())
  agent_id       String
  status         String    @default("provisioning") // provisioning | warm | claimed | dead
  task_arn       String?
  sandbox_url    String?
  failure_reason String?
  created_at     DateTime  @default(now())
  ready_at       DateTime?
  claimed_at     DateTime?

  agent Agent @relation(fields: [agent_id], references: [agent_id], onDelete: Cascade)

  @@index([agent_id, status, ready_at])
  @@index([status, created_at])
  @@map("managed_agent_warm_task")
}

// Per-agent durable memory.
model Memory {
  memory_id         String   @id @default(uuid())
  agent_id          String
  text              String

  tags              String[]
  type              String   @default("convention")

  priority          Int      @default(0)
  disabled          Boolean  @default(false)

  times_applied     Int      @default(0)
  last_applied_at   DateTime?

  source            String   @default("agent")
  source_user_id    String?
  source_session_id String?
  source_thread_ts  String?

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  agent Agent @relation(fields: [agent_id], references: [agent_id], onDelete: Cascade)

  @@index([agent_id, disabled, priority])
  @@map("managed_agent_memory")
}

// =============================================================================
// Integrations subsystem (src/server/integrations/)
// =============================================================================
// Three tables let external mediums (Linear, Slack, GitHub, ...) delegate work
// to an Agent and stream activity back. Each agent has its own OAuth app per
// medium — credentials live on AgentIntegrationConfig (not env vars), so one
// LAP deployment can host N delegateable agents each appearing as a distinct
// app-user in the medium.
// =============================================================================

/// Per-agent OAuth-app credentials for one medium. Created when the operator
/// pastes their Linear app's `client_id`, `client_secret`, `webhook_secret`
/// in the agent's Integrations panel. `enabled = false` keeps the row but
/// makes the routes reject inbound webhooks and OAuth attempts.
///
/// Secrets are AES-256-GCM encrypted at rest by core/crypto.ts when
/// INTEGRATION_TOKEN_KEY is configured (required in production).
model AgentIntegrationConfig {
  agent_id           String
  integration_id     String                          // "linear" | "slack" | "github" | ...
  enabled            Boolean   @default(true)
  client_id          String                          // OAuth client id (public — not encrypted)
  client_secret_enc  String                          // encrypted
  webhook_secret_enc String                          // encrypted
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  created_by         String?

  agent    Agent                @relation(fields: [agent_id], references: [agent_id], onDelete: Cascade)
  installs IntegrationInstall[]

  @@id([agent_id, integration_id])
  @@map("agent_integration_config")
}

/// One OAuth install per (agent, medium, workspace). The (agent_id,
/// integration_id) pair is a composite FK back to AgentIntegrationConfig.
model IntegrationInstall {
  install_id     String    @id @default(uuid())
  agent_id       String
  integration_id String
  workspace_id   String
  workspace_name String
  access_token   String    // encrypted
  refresh_token  String?   // encrypted
  expires_at     DateTime?
  metadata       Json      @default("{}") // medium extras: app_user_id, bot_user_id, etc.
  created_at     DateTime  @default(now())
  created_by     String?

  agent             Agent                  @relation(fields: [agent_id], references: [agent_id], onDelete: Cascade)
  config            AgentIntegrationConfig @relation(fields: [agent_id, integration_id], references: [agent_id, integration_id], onDelete: Cascade)
  external_sessions IntegrationSession[]

  @@unique([agent_id, integration_id, workspace_id])
  @@index([agent_id, integration_id])
  @@map("integration_install")
}

/// Maps a medium's session id (e.g. Linear agentSession.id) to a LAP Session.
model IntegrationSession {
  external_session_id String   @id        // medium's id
  session_id          String   @unique    // LAP managed_agent_session.session_id
  install_id          String
  external_ref        String?             // "LIT-1234", PR url — for logs
  last_status         String?
  last_pr_url         String?
  created_at          DateTime @default(now())

  session Session            @relation(fields: [session_id], references: [session_id], onDelete: Cascade)
  install IntegrationInstall @relation(fields: [install_id], references: [install_id], onDelete: Cascade)

  @@index([install_id])
  @@map("integration_session")
}
